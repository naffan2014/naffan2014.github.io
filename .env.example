# 又拍云对象存储凭证(publish 服务用)
# 复制此文件为 .env 并填入真实凭证
# .env 已在 .gitignore 中,不会被提交
#
# 获取方式:
#   1. 登录又拍云控制台 https://console.upyun.com/
#   2. 进入「云存储」→ 找到你的服务(如 naffanwpstorage)
#   3. 服务名 = UPYUN_BUCKET
#   4. 进入「操作员管理」→ 创建/查看操作员
#   5. 操作员名 = UPYUN_OPERATOR,密码 = UPYUN_PASSWORD

UPYUN_BUCKET=naffanwpstorage
UPYUN_OPERATOR=naffan
UPYUN_PASSWORD=your_operator_password_here
